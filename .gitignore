# ============================================================
# Infra-Pilot — .gitignore
# ============================================================

# Secrets & Credentials (NEVER commit these)
.env
credentials/
*.json
!package.json
!vite.config.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
pip-log.txt

# Temporary workspace (ephemeral)
.tmp/

# Node / React
frontend/node_modules/
frontend/dist/
frontend/.vite/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
