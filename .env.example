# ============================================================
# Infra-Pilot — .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file.
# ============================================================

# ── GitHub ─────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here

# ── Google Gemini (AI — free tier) ─────────────────────────
GEMINI_API_KEY=AIza_your_key_here

# ── Google Sheets / GCP Service Account ────────────────────
# Path to the downloaded service account JSON
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/gcp_service_account.json
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# ── Email (SMTP — Gmail App Password recommended) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
# Comma-separated list of recipients
EMAIL_RECIPIENTS=your_email@gmail.com

# ── Ollama (Local LLM) ─────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Available: llama3, wizardlm, gemma4 (must be pulled first)
OLLAMA_DEFAULT_MODEL=llama3

# ── Backend (FastAPI) ──────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8000

# ── Frontend (Vite) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
